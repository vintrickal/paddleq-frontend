{
  "openapi": "3.0.4",
  "info": {
    "title": "PaddleQ API",
    "description": "Backend API for the PaddleQ pickleball queueing system.",
    "version": "v1"
  },
  "paths": {
    "/api/matches/next": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Form the next match from the queue",
        "description": "Picks the most-deserving Waiting players and forms a match on the next available court. Set allowSkillMix=true to allow players within ±0.5 skill if strict matching fails.",
        "parameters": [
          {
            "name": "allowSkillMix",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Match formed.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/FormMatchResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormMatchResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/FormMatchResponse"
                }
              }
            }
          },
          "409": {
            "description": "Could not form a match (no session, no courts, or insufficient players)."
          }
        }
      }
    },
    "/api/matches/{id}/complete": {
      "post": {
        "tags": [
          "Matches"
        ],
        "summary": "Complete a match and record the winner",
        "description": "Marks the match as Completed, updates win/loss records, and returns players to Waiting status.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteMatchRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteMatchRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteMatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Match completed.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              }
            }
          },
          "404": {
            "description": "Match not found."
          },
          "409": {
            "description": "Match is not in progress."
          }
        }
      }
    },
    "/api/matches/{id}": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "Get a match by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Match found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/MatchResponse"
                }
              }
            }
          },
          "404": {
            "description": "Match not found."
          }
        }
      }
    },
    "/api/matches/active": {
      "get": {
        "tags": [
          "Matches"
        ],
        "summary": "List all in-progress matches in the active session",
        "description": "Returns matches currently being played, ordered by court number.",
        "responses": {
          "200": {
            "description": "List of active matches.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MatchResponse"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MatchResponse"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MatchResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/players": {
      "post": {
        "tags": [
          "Players"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePlayerRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePlayerRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePlayerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/players/{id}": {
      "get": {
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/players/{publicId}": {
      "get": {
        "tags": [
          "Players"
        ],
        "parameters": [
          {
            "name": "publicId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlayerResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/queue/check-in": {
      "post": {
        "tags": [
          "Queue"
        ],
        "summary": "Check in a player by QR code",
        "description": "Looks up a player by their QR code and adds them to the queue for the currently active session. If the player was 'Resting,' they are returned to 'Waiting' status.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Player checked in.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/CheckInResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckInResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/CheckInResponse"
                }
              }
            }
          },
          "404": {
            "description": "QR code does not match any player."
          },
          "409": {
            "description": "No active session, or player is already queued/finished."
          }
        }
      }
    },
    "/api/queue/leave": {
      "post": {
        "tags": [
          "Queue"
        ],
        "summary": "Leave the queue (rest)",
        "description": "Moves a player from 'Waiting' to 'Resting' status. The player can rejoin later by checking in again with their QR code. Players currently in a match cannot leave.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CheckInRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Player has left the queue.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveQueueResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveQueueResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LeaveQueueResponse"
                }
              }
            }
          },
          "404": {
            "description": "QR code does not match any player."
          },
          "409": {
            "description": "Player is not in the queue, or cannot leave right now."
          }
        }
      }
    },
    "/api/queue": {
      "get": {
        "tags": [
          "Queue"
        ],
        "summary": "Get the current queue",
        "description": "Returns all queue entries for the currently active session, along with session context and a status summary. If there is no active session, returns an empty queue with ActiveSession = null.",
        "responses": {
          "200": {
            "description": "Queue retrieved.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/QueueResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueueResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "Start a new session",
        "description": "Creates and immediately activates a new play session with the specified match type and court count. Only one session can be active at a time.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session started.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input."
          },
          "409": {
            "description": "An active session already exists."
          }
        }
      },
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "List all sessions",
        "description": "Returns sessions ordered by most recent first.",
        "responses": {
          "200": {
            "description": "List of sessions.",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionResponse"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionResponse"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SessionResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sessions/active": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Get the currently active session",
        "responses": {
          "200": {
            "description": "Active session.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "404": {
            "description": "No active session."
          }
        }
      }
    },
    "/api/sessions/{id}": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Get a session by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session found.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Session not found."
          }
        }
      },
      "put": {
        "tags": [
          "Sessions"
        ],
        "summary": "Update an active session",
        "description": "Updates session settings. Only allowed while session is Active.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSessionRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSessionRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session updated.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Session not found."
          },
          "409": {
            "description": "Session is not active."
          }
        }
      }
    },
    "/api/sessions/{id}/end": {
      "post": {
        "tags": [
          "Sessions"
        ],
        "summary": "End an active session",
        "description": "Closes the session. After this, no more matches or queue entries can be tied to it.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Session ended.",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          },
          "404": {
            "description": "Session not found."
          },
          "409": {
            "description": "Session is not active."
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CheckInRequest": {
        "required": [
          "qrCode"
        ],
        "type": "object",
        "properties": {
          "qrCode": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CheckInResponse": {
        "type": "object",
        "properties": {
          "queueEntryId": {
            "type": "integer",
            "format": "int32"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          },
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "skillLevel": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "checkedInAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "CompleteMatchRequest": {
        "required": [
          "winningTeam"
        ],
        "type": "object",
        "properties": {
          "winningTeam": {
            "maximum": 2,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreatePlayerRequest": {
        "required": [
          "name",
          "skillLevel"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "skillLevel": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "CreateSessionRequest": {
        "required": [
          "matchType",
          "numberOfCourts"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "matchType": {
            "minLength": 1,
            "type": "string"
          },
          "numberOfCourts": {
            "maximum": 20,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "FormMatchResponse": {
        "type": "object",
        "properties": {
          "match": {
            "$ref": "#/components/schemas/MatchResponse"
          },
          "usedSkillMix": {
            "type": "boolean"
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LeaveQueueResponse": {
        "type": "object",
        "properties": {
          "queueEntryId": {
            "type": "integer",
            "format": "int32"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          },
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "leftAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "MatchPlayerInfo": {
        "type": "object",
        "properties": {
          "playerId": {
            "type": "string",
            "format": "uuid"
          },
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "skillLevel": {
            "type": "number",
            "format": "double"
          },
          "team": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "MatchResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "matchType": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "courtNumber": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "winningTeam": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "completedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "players": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MatchPlayerInfo"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PlayerResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "skillLevel": {
            "type": "number",
            "format": "double"
          },
          "qrCode": {
            "type": "string",
            "nullable": true
          },
          "wins": {
            "type": "integer",
            "format": "int32"
          },
          "losses": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "QueueEntryResponse": {
        "type": "object",
        "properties": {
          "queueEntryId": {
            "type": "integer",
            "format": "int32"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          },
          "playerName": {
            "type": "string",
            "nullable": true
          },
          "skillLevel": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "gamesPlayed": {
            "type": "integer",
            "format": "int32"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "checkedInAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "lastPlayedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "QueueResponse": {
        "type": "object",
        "properties": {
          "activeSession": {
            "$ref": "#/components/schemas/SessionResponse"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/QueueEntryResponse"
            },
            "nullable": true
          },
          "summary": {
